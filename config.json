      "guestPort": 9090
    },
    {
      "protocol": "tcp",
      "hostAddress": "127.0.0.1",
      "hostPort": 8080,
      "guestPort": 9092
    },
    {
      "protocol": "tcp",
      "hostAddress": "127.0.0.1",
      "hostPort": 9092,
      "guestPort": 9092
    },
    {
      "protocol": "tcp",
      "hostAddress": "127.0.0.1",
      "hostPort": 3002,
      "guestPort": 3000
    },
    {
      "protocol": "tcp",
      "hostAddress": "127.0.0.1",
      "hostPort": 2222,
      "guestPort": 22
